#!/bin/sh

set -eu

R_SCRIPT="${R_HOME}/bin/Rscript"

if [ ! -x "${R_SCRIPT}" ]; then
  echo "ERROR: Rscript not found at ${R_SCRIPT}" >&2
  exit 1
fi

if ! RDUCKHTS_DIR=$("${R_SCRIPT}" -e "cat(normalizePath(system.file(package = 'Rduckhts'), winslash = '/', mustWork = TRUE))" 2>/dev/null); then
  echo "ERROR: Rduckhts must be installed before building RWisecondorX" >&2
  exit 1
fi

HTSLIB_DIR="${RDUCKHTS_DIR}/duckhts_extension/htslib"
HTSLIB_LIB=""

for candidate in \
  "${HTSLIB_DIR}/lib/libhts.a" \
  "${HTSLIB_DIR}/libhts.a"
do
  if [ -f "${candidate}" ]; then
    HTSLIB_LIB="${candidate}"
    break
  fi
done

if [ -z "${HTSLIB_LIB}" ]; then
  echo "ERROR: Could not find bundled libhts.a under ${HTSLIB_DIR}" >&2
  exit 1
fi

if [ ! -f "${HTSLIB_DIR}/include/htslib/sam.h" ] && [ ! -f "${HTSLIB_DIR}/htslib/sam.h" ]; then
  echo "ERROR: Could not find htslib headers under ${HTSLIB_DIR}" >&2
  exit 1
fi

cat > src/Makevars <<EOF
# Generated by configure. Do not edit by hand.
RDUCKHTS_HTSLIB_DIR = ${HTSLIB_DIR}
RDUCKHTS_HTSLIB_LIB = ${HTSLIB_LIB}

PKG_CXXFLAGS = \$(SHLIB_OPENMP_CXXFLAGS)
PKG_CPPFLAGS = -I"\$(RDUCKHTS_HTSLIB_DIR)" -I"\$(RDUCKHTS_HTSLIB_DIR)/include"
PKG_LIBS = \$(SHLIB_OPENMP_CXXFLAGS) \\
  "\$(RDUCKHTS_HTSLIB_LIB)" \\
  -lz -lbz2 -llzma -lpthread \\
  \$(LAPACK_LIBS) \$(BLAS_LIBS) \$(FLIBS)
EOF

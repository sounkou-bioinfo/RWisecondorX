#!/bin/sh

set -eu

R_SCRIPT="${R_HOME}/bin/Rscript"

if [ ! -x "${R_SCRIPT}" ]; then
  echo "ERROR: Rscript not found at ${R_SCRIPT}" >&2
  exit 1
fi

if ! RDUCKHTS_DIR=$("${R_SCRIPT}" -e "cat(normalizePath(system.file(package = 'Rduckhts'), winslash = '/', mustWork = TRUE))" 2>/dev/null); then
  echo "ERROR: Rduckhts must be installed before building RWisecondorX" >&2
  exit 1
fi

# Prefer htslib_config.R shipped by Rduckhts – it encodes the exact
# compiler/linker flags (including optional libdeflate, libcurl, etc.)
# that match how the bundled libhts.a was built on this platform.
HTSLIB_CONFIG="${RDUCKHTS_DIR}/htslib_config.R"

if [ -f "${HTSLIB_CONFIG}" ]; then
  echo "Using Rduckhts htslib_config.R for htslib flags"
  PKG_CPPFLAGS=$("${R_SCRIPT}" -e "source('${HTSLIB_CONFIG}'); cat(htslib_cflags())")
  PKG_HTSLIB_LIBS=$("${R_SCRIPT}" -e "source('${HTSLIB_CONFIG}'); cat(htslib_libs(static=TRUE))")
else
  # Fallback for Rduckhts versions that predate htslib_config.R.
  echo "INFO: htslib_config.R not found in Rduckhts; falling back to manual path discovery"
  HTSLIB_DIR="${RDUCKHTS_DIR}/duckhts_extension/htslib"
  HTSLIB_LIB=""
  for candidate in \
    "${HTSLIB_DIR}/lib/libhts.a" \
    "${HTSLIB_DIR}/libhts.a"
  do
    if [ -f "${candidate}" ]; then
      HTSLIB_LIB="${candidate}"
      break
    fi
  done
  if [ -z "${HTSLIB_LIB}" ]; then
    echo "ERROR: Could not find bundled libhts.a under ${HTSLIB_DIR}" >&2
    exit 1
  fi
  if [ ! -f "${HTSLIB_DIR}/include/htslib/sam.h" ] && [ ! -f "${HTSLIB_DIR}/htslib/sam.h" ]; then
    echo "ERROR: Could not find htslib headers under ${HTSLIB_DIR}" >&2
    exit 1
  fi
  PKG_CPPFLAGS="-I\"${HTSLIB_DIR}/include\" -I\"${HTSLIB_DIR}\""
  PKG_HTSLIB_LIBS="\"${HTSLIB_LIB}\" -lz -lbz2 -llzma -lpthread"
fi

cat > src/Makevars <<EOF
# Generated by configure. Do not edit by hand.

PKG_CXXFLAGS = \$(SHLIB_OPENMP_CXXFLAGS)
PKG_CPPFLAGS = ${PKG_CPPFLAGS}
PKG_LIBS = \$(SHLIB_OPENMP_CXXFLAGS) \\
  ${PKG_HTSLIB_LIBS} \\
  \$(LAPACK_LIBS) \$(BLAS_LIBS) \$(FLIBS)
EOF
